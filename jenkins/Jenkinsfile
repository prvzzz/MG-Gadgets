pipeline {
    agent any

    options {
        skipDefaultCheckout(true)
    }

    environment {
        GIT_REPO = "https://github.com/prvzzz/MG-Gadgets.git"
        GIT_BRANCH = "main"
        GIT_CREDENTIALS = "github-pat"
        AWS_REGION = "us-east-1"
        ECR_REPOSITORY = "mg-devops-dev-ecr"
        IMAGE_NAME = "mg-consumer-ssr"
        IMAGE_TAG = "${BUILD_NUMBER}"
        AWS_ACCOUNT_ID = "149828426205"
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Verify Workspace') {
            steps {
                sh '''
                    pwd
                    ls -la
                    ls -la apps
                '''
            }
        }

        stage('Build Docker Image') {
            steps {
                dir('apps/consumer-ssr') {
                    sh '''
                        docker build \
                        -t ${IMAGE_NAME}:${IMAGE_TAG} .
                    '''
                }
            }
        }

        stage('Verify Docker Image') {
            steps {
                sh '''
                    docker images | grep ${IMAGE_NAME}
                '''
            }
        }

        stage('Configure Git') {
            steps {
                sh '''
                    git config --global user.name "Jenkins CI"
                    git config --global user.email "jenkins@mggadgets.com"
                '''
            }
        }

        stage('Login to Amazon ECR') {
            steps {
                sh '''
                     aws ecr get-login-password \
                     --region ${AWS_REGION} | docker login \
                     --username AWS \
                     --password-stdin \
                  ${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com
                  '''
             }
        }
        stage('Push Image to Amazon ECR') {
            steps {
                sh '''
                docker tag ${IMAGE_NAME}:${IMAGE_TAG} \
                ${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com/${ECR_REPOSITORY}:${IMAGE_TAG}

                docker push \
                ${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com/${ECR_REPOSITORY}:${IMAGE_TAG}
                '''
             }
        }
    }

    post {
        success {
            echo 'Pipeline completed successfully.'
        }

        failure {
            echo 'Pipeline failed.'
        }
    }
}
